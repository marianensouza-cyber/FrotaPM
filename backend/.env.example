# Server
PORT=5000
NODE_ENV=development

# Database (use sqlite para desenvolvimento rápido)
DB_TYPE=sqlite
# DB_TYPE=postgres

# Se usar PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=frotapm
# DB_USER=postgres
# DB_PASSWORD=your_password

# Se usar SQLite:
DB_FILE=./data/frotapm.db

# Frontend URL
FRONTEND_URL=http://localhost:5173
